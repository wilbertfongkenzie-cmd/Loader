function DoFakeBombJump()
    if not BombEnabled then
        WindUI:Notify({Title = "Fake Bomb", Content = "Feature not enabled!", Duration = 1})
        return
    end
    if BombCooldownActive then
        WindUI:Notify({Title = "Fake Bomb", Content = "Cooldown: " .. math.ceil(BombRemainingTime) .. "s left", Duration = 1})
        return
    end
    local fakeBomb = nil
    if lp.Character then fakeBomb = lp.Character:FindFirstChild("FakeBomb") end
    if not fakeBomb and lp.Backpack then fakeBomb = lp.Backpack:FindFirstChild("FakeBomb") end
    if not fakeBomb then
        local replicateRemote = ReplicatedStorage:FindFirstChild("Remotes") and ReplicatedStorage.Remotes:FindFirstChild("Extras") and ReplicatedStorage.Remotes.Extras:FindFirstChild("ReplicateToy")
        if replicateRemote then
            pcall(function() replicateRemote:InvokeServer("FakeBomb") end)
            task.wait(0.1)
            if lp.Character then fakeBomb = lp.Character:FindFirstChild("FakeBomb") end
            if not fakeBomb and lp.Backpack then fakeBomb = lp.Backpack:FindFirstChild("FakeBomb") end
        end
    end
    if not fakeBomb then
        WindUI:Notify({Title = "Fake Bomb", Content = "Could not get FakeBomb tool!", Duration = 2})
        return
    end
    if fakeBomb.Parent == lp.Backpack then
        local hum = lp.Character and lp.Character:FindFirstChild("Humanoid")
        if hum then hum:EquipTool(fakeBomb); task.wait(0.1) end
    end
    local bombRemote = fakeBomb:FindFirstChild("RemoteEvent")
    if not bombRemote or not bombRemote:IsA("RemoteEvent") then
        for _, child in pairs(fakeBomb:GetChildren()) do
            if child:IsA("RemoteEvent") then bombRemote = child; break end
        end
    end
    if not bombRemote then
        WindUI:Notify({Title = "Fake Bomb", Content = "No RemoteEvent found in FakeBomb!", Duration = 2})
        return
    end

    local position = GetCenterPosition()
    if not position then
        WindUI:Notify({Title = "Fake Bomb", Content = "Cannot get position!", Duration = 1})
        return
    end

    local success = pcall(function() bombRemote:FireServer(position, 50) end)
    if success then
        MakeCharacterJump()
        StartBombCooldown()
        WindUI:Notify({Title = "Fake Bomb", Content = "Bomb placed! Cooldown: " .. BombCooldown .. "s", Duration = 1})
    else
        WindUI:Notify({Title = "Fake Bomb", Content = "Failed to place bomb!", Duration = 1})
    end
end

