local flyEnabled = false
local flyConnection = nil
local flyDir = { f = 0, b = 0, l = 0, r = 0 }
local function startFlyInternal()
    if flyConnection then flyConnection:Disconnect() end
    local char = lp.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    local root = char:FindFirstChild("HumanoidRootPart")
    if not (hum and root) then return end
    local oldGrav = workspace.Gravity
    local oldPlatform = hum.PlatformStand
    workspace.Gravity = 0
    hum.PlatformStand = true
    local gyro = Instance.new("BodyGyro", root)
    gyro.P = 20000
    gyro.maxTorque = Vector3.new(math.huge, math.huge, math.huge)
    local velo = Instance.new("BodyVelocity", root)
    velo.maxForce = Vector3.new(math.huge, math.huge, math.huge)
    flyConnection = RunService.Heartbeat:Connect(function()
        if not flyEnabled or not char.Parent then
            gyro:Destroy(); velo:Destroy()
            workspace.Gravity = oldGrav
            hum.PlatformStand = oldPlatform
            flyConnection:Disconnect()
            flyConnection = nil
            return
        end
        local dir = Vector3.new(flyDir.l + flyDir.r, 0, flyDir.f + flyDir.b)
        local worldDir = Camera.CFrame:VectorToWorldSpace(dir).Unit
        velo.Velocity = (dir.Magnitude <= 0) and Vector3.new(0,0,0) or (worldDir * _G.FlySpeed)
        gyro.CFrame = Camera.CFrame
    end)
end

UserInputService.InputBegan:Connect(function(input,gp)
    if gp or not flyEnabled then return end
    local k = input.KeyCode.Name:lower()
    if k=="w" then flyDir.f = -1 elseif k=="s" then flyDir.b = 1
    elseif k=="a" then flyDir.l = -1 elseif k=="d" then flyDir.r = 1 end
end)

