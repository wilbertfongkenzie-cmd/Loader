end

local function throwAction()
    if ThrowCooldownFlag then return false end
    if not isPlayerMurderer(lp) then
        WindUI:Notify({Title = "Throw", Content = "You are not the Murderer!", Duration = 1})
        return false
    end
    local knife = getMyKnife()
    if not knife then
        WindUI:Notify({Title = "Throw", Content = "No knife found!", Duration = 1})
        return false
    end
    local target, _ = GetClosestTarget()
    if not target or not target:FindFirstChild("HumanoidRootPart") then
        WindUI:Notify({Title = "Throw", Content = "No target nearby!", Duration = 1})
        return false
    end
    local targetRoot = target:FindFirstChild("HumanoidRootPart") or target:FindFirstChild("Torso")
    local targetHumanoid = target:FindFirstChildOfClass("Humanoid")
    if not targetRoot or not targetHumanoid then return false end

    if knife.Parent == lp.Backpack then
        local hum = lp.Character and lp.Character:FindFirstChildOfClass("Humanoid")
        if hum then hum:EquipTool(knife); task.wait(0.1) end
    end
    if knife.Parent ~= lp.Character then
        WindUI:Notify({Title = "Throw", Content = "Failed to equip knife!", Duration = 1})
        return false
    end

    local myHRP = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
    if not myHRP then return false end

    ThrowCooldownFlag = true
    task.delay(THROW_COOLDOWN, function() ThrowCooldownFlag = false end)

    if THROW_MODE == "Animated" then
        PlayThrowAnimationSequence()
        task.wait(ANIMATION_DELAY)
    end

    local origin = myHRP.Position
    local predictedPos = GetKnifePredictedPosition(targetRoot, targetHumanoid)

    if lp.Character then RaycastParameters.FilterDescendantsInstances = {lp.Character} end
    local direction = (predictedPos - origin).Unit * 200
    local raycastResult = workspace:Raycast(origin, direction, RaycastParameters)
    local finalPos = raycastResult and raycastResult.Position or predictedPos

    -- ==================== CARI REMOTE DENGAN PRIORITAS ====================
    local throwRemote = nil
    -- Cari di seluruh turunan knife
    local function findRemote(obj)
        for _, child in pairs(obj:GetChildren()) do
            if child:IsA("RemoteEvent") or child:IsA("RemoteFunction") then
                if child.Name == "FlingKnife" then return child end
                if child.Name == "Throwingknifeserver" then return child end
                if child.Name == "Knifeserver" then return child end
            end
            local found = findRemote(child)
            if found then return found end
        end
        return nil
    end
    throwRemote = findRemote(knife)

    -- Jika tidak ketemu, coba cari di ReplicatedStorage
    if not throwRemote then
        local rs = game:GetService("ReplicatedStorage")
        throwRemote = rs:FindFirstChild("FlingKnife") or rs:FindFirstChild("Throwingknifeserver") or rs:FindFirstChild("Knifeserver")
    end

    -- Fallback: remote event pertama di knife
    if not throwRemote then
        for _, child in pairs(knife:GetDescendants()) do
            if child:IsA("RemoteEvent") then
                throwRemote = child
                break
            end
        end
    end

    if not throwRemote then
        WindUI:Notify({Title = "Throw Error", Content = "No remote found!", Duration = 2})
        return false
    end

    -- HANYA SATU ARGUMEN: CFrame posisi prediksi
    local args = { CFrame.new(finalPos) }

    local success = false
    if throwRemote:IsA("RemoteEvent") then
        success = pcall(function() throwRemote:FireServer(unpack(args)) end)
    elseif throwRemote:IsA("RemoteFunction") then
        success = pcall(function() throwRemote:InvokeServer(unpack(args)) end)
    end

    if success then
        WindUI:Notify({Title = "Throw", Content = "Thrown at " .. target.Name, Duration = 1})
        return true
    else
        WindUI:Notify({Title = "Throw", Content = "Throw failed!", Duration = 2})
        return false
    end
end

