local timerEnabled = false
local timerGui = nil
local timerTextLabel = nil
local murderCheckConnection = nil
local timerUpdateConnection = nil
local lastMurderState = false
local resetCooldown = false

-- Fungsi untuk mendapatkan Murderer
local function GetMurderer()
    for _, plr in ipairs(game.Players:GetPlayers()) do
        if plr ~= game.Players.LocalPlayer then
            local char = plr.Character
            local bp = plr:FindFirstChild("Backpack")
            if (char and char:FindFirstChild("Knife")) or (bp and bp:FindFirstChild("Knife")) then
                return plr
            end
        end
    end
    return nil
end

-- Fungsi cek apakah murderer sudah mati atau tidak ada
local function IsMurdererDead()
    local murderer = GetMurderer()
    
    -- Jika tidak ada murderer sama sekali (sudah mati/respawn)
    if not murderer then
        return true
    end
    
    local char = murderer.Character
    if not char then
        return true
    end
    
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not humanoid then
        return true
    end
    
    -- Cek health
    if humanoid.Health <= 0 then
        return true
    end
    
    return false
end

-- Fungsi reset timer Text Label ke 0:00 (PAKSA)
local function ResetTimerToZero()
    local success = false
    
    -- Reset via timerTextLabel
    if timerTextLabel and timerTextLabel:IsA("TextLabel") then
        timerTextLabel.Text = "0:00"
        timerTextLabel.TextColor3 = Color3.new(1, 1, 1)
        timerTextLabel.TextTransparency = 0
        success = true
    end
    
    -- Reset via CoreGui
    local gui = game:GetService("CoreGui"):FindFirstChild("TimerGui")
    if gui then
        local label = gui:FindFirstChild("TimerText")
        if label and label:IsA("TextLabel") then
            label.Text = "0:00"
            label.TextColor3 = Color3.new(1, 1, 1)
            label.TextTransparency = 0
            timerTextLabel = label
            success = true
        end
    end
    
    -- Reset via RoundTimerPart (paksa)
    local roundTimerPart = workspace:FindFirstChild("RoundTimerPart")
    if roundTimerPart then
        local surfaceGui = roundTimerPart:FindFirstChild("SurfaceGui")
        if surfaceGui then
            local timer = surfaceGui:FindFirstChild("Timer")
            if timer and timer:IsA("TextLabel") then
                timer.Text = "0:00"
                success = true
            end
        end
    end
    
    return success
end

-- Fungsi membuat Timer GUI
local function CreateTimerGUI()
    if timerGui then
        timerGui:Destroy()
        timerGui = nil
        timerTextLabel = nil
    end
    
    timerGui = Instance.new("ScreenGui")
    timerGui.Name = "TimerGui"
    timerGui.Parent = game:GetService("CoreGui")
    
    timerTextLabel = Instance.new("TextLabel")
    timerTextLabel.Name = "TimerText"
    timerTextLabel.BackgroundTransparency = 1
    timerTextLabel.TextColor3 = Color3.new(1, 1, 1)
    timerTextLabel.TextStrokeColor3 = Color3.new(0, 0, 0)
    timerTextLabel.TextStrokeTransparency = 0.5
    timerTextLabel.TextScaled = true
    timerTextLabel.AnchorPoint = Vector2.new(0.5, 0.5)
    timerTextLabel.Position = UDim2.new(0.5, 0, 0.1, 0)
    timerTextLabel.Size = UDim2.new(0, 200, 0, 50)
    timerTextLabel.Font = Enum.Font.GothamBold
    timerTextLabel.Text = "0:00"
    timerTextLabel.Parent = timerGui
    
    return timerGui
end

-- Fungsi start murder checker (LOOP TERUS)
local function StartMurderChecker()
    if murderCheckConnection then
        murderCheckConnection:Disconnect()
        murderCheckConnection = nil
    end
    
    -- Gunakan heartbeat untuk cek terus
    murderCheckConnection = game:GetService("RunService").Heartbeat:Connect(function()
        if not timerEnabled then return end
        
        local isDead = IsMurdererDead()
        
        -- Jika murderer mati atau tidak ada
        if isDead then
            -- Reset timer jika belum di-reset
            if not lastMurderState then
                ResetTimerToZero()
                lastMurderState = true
            end
        else
            -- Murderer hidup kembali
            if lastMurderState then
                lastMurderState = false
            end
        end
    end)
end

-- Fungsi stop semua
local function StopTimer()
    timerEnabled = false
    lastMurderState = false
    
    if murderCheckConnection then
        murderCheckConnection:Disconnect()
        murderCheckConnection = nil
    end
    
    if timerUpdateConnection then
        timerUpdateConnection:Disconnect()
        timerUpdateConnection = nil
    end
    
    if timerGui then
        timerGui:Destroy()
        timerGui = nil
        timerTextLabel = nil
    end
end

