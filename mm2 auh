-- Knife prediction functions
local function GetMegaPrediction(targetRoot, targetHumanoid)
    if not targetRoot or not targetHumanoid then return targetRoot and targetRoot.Position or Vector3.new(0,0,0) end
    local velocity = targetRoot.AssemblyLinearVelocity
    local moveDir = targetHumanoid.MoveDirection
    local playerPosition = targetRoot.Position
    local seismicPos = playerPosition
    if velocity.Magnitude ~= 0 then
        local pred = velocity.Unit * velocity.Magnitude / 16.5
        local y = pred.Y
        y = y > 2.65 and 2.65 or (y < -2 and -2 or y)
        seismicPos = playerPosition + Vector3.new(pred.X, y, pred.Z / 1.25)
    end
    local overflowPos = playerPosition
    if velocity.Magnitude ~= 0 then
        local pred = velocity.Unit * velocity.Magnitude / 17 + moveDir
        local y = pred.Y
        y = y > 2.5 and 2.5 or (y < -2 and -2 or y)
        overflowPos = playerPosition + Vector3.new(pred.X, y, pred.Z)
    end
    local predictedPos = (seismicPos + overflowPos) / 2
    local distance = (predictedPos - playerPosition).Magnitude
    if distance > 30 then predictedPos = playerPosition end
    return predictedPos
end
-- ==================== PREDICTION MODES (15 total) ====================
-- Mode New (agresif + deteksi lompatan)
local function getNewPrediction(targetRoot, targetHumanoid)
    local pos = targetRoot.Position
    local vel = targetRoot.AssemblyLinearVelocity
    local moveDir = targetHumanoid.MoveDirection
    local isJumping = (targetHumanoid.JumpPower > 0 and targetHumanoid.FloorMaterial == Enum.Material.Air)
    local jumpBonus = isJumping and Vector3.new(0, 7.5, 0) or Vector3.new(0, 0, 0)
    return pos + vel * 0.4 + moveDir * 2.5 + jumpBonus
end

-- Mode Extreme (akselerasi + zig-zag)
local lastVelocities = {}
local function getExtremePrediction(targetRoot, targetHumanoid)
    local pos = targetRoot.Position
    local vel = targetRoot.AssemblyLinearVelocity
    local moveDir = targetHumanoid.MoveDirection
    local targetKey = tostring(targetRoot)
    local lastVel = lastVelocities[targetKey] or vel
    local accel = (vel - lastVel) / 0.1
    lastVelocities[targetKey] = vel
    task.delay(2, function() lastVelocities[targetKey] = nil end)
    local predTime = 0.22
    local predictedPos = pos + vel * predTime + 0.5 * accel * (predTime ^ 2)
    local cross = vel.Unit:Cross(moveDir)
    local zigzag = cross * 1.5
    predictedPos = predictedPos + moveDir * 2 + zigzag
    return predictedPos
end

-- Mode Ultimate (weighted ensemble + history)
local positionHistory = {}
local function getUltimatePrediction(targetRoot, targetHumanoid, ping)
    local pos = targetRoot.Position
    local vel = targetRoot.AssemblyLinearVelocity
    local moveDir = targetHumanoid.MoveDirection
    local targetKey = tostring(targetRoot)
    if not positionHistory[targetKey] then positionHistory[targetKey] = {} end
    local history = positionHistory[targetKey]
    table.insert(history, pos)
    if #history > 5 then table.remove(history, 1) end

    local function linearRegression(historyList)
        if #historyList < 2 then return pos end
        local n = #historyList
        local sumX, sumY, sumXY, sumX2 = 0, 0, 0, 0
        for i, p in ipairs(historyList) do
            local x = i
            sumX = sumX + x
            sumY = sumY + p.X
            sumXY = sumXY + x * p.X
            sumX2 = sumX2 + x * x
        end
        local slopeX = (n * sumXY - sumX * sumY) / (n * sumX2 - sumX * sumX)
        local interceptX = (sumY - slopeX * sumX) / n
        local predX = interceptX + slopeX * (n + 1)

        sumY, sumXY, sumX2 = 0, 0, 0
        for i, p in ipairs(historyList) do
            local x = i
            sumY = sumY + p.Y
            sumXY = sumXY + x * p.Y
            sumX2 = sumX2 + x * x
        end
        local slopeY = (n * sumXY - sumX * sumY) / (n * sumX2 - sumX * sumX)
        local interceptY = (sumY - slopeY * sumX) / n
        local predY = interceptY + slopeY * (n + 1)

        sumY, sumXY, sumX2 = 0, 0, 0
        for i, p in ipairs(historyList) do
            local x = i
            sumY = sumY + p.Z
            sumXY = sumXY + x * p.Z
            sumX2 = sumX2 + x * x
        end
        local slopeZ = (n * sumXY - sumX * sumY) / (n * sumX2 - sumX * sumX)
        local interceptZ = (sumY - slopeZ * sumX) / n
        local predZ = interceptZ + slopeZ * (n + 1)
        return Vector3.new(predX, predY, predZ)
    end

    local regressedPos = linearRegression(history)
    local predDefault = getDefaultPrediction(pos, vel, moveDir)
    local predV2 = getV2Prediction(pos, vel)
    local predHybrid = (predDefault + predV2) / 2
    local predMega = GetMegaPrediction(targetRoot, targetHumanoid)
    local predNew = getNewPrediction(targetRoot, targetHumanoid)
    local predExtreme = getExtremePrediction(targetRoot, targetHumanoid)
    local speed = vel.Magnitude
    local regWeight = math.clamp(speed / 30, 0.2, 0.8)
    local finalPos = (predDefault * 0.1 + predV2 * 0.1 + predHybrid * 0.1 +
                      predMega * 0.15 + predNew * 0.15 + predExtreme * 0.2) * (1 - regWeight) +
                      regressedPos * regWeight
    local pingComp = (ping or 0) * 0.12
    return finalPos + (vel * pingComp)
end

-- Mode Omni (rata-rata 9 mode dasar)
local function getOmniPrediction(targetRoot, targetHumanoid, ping)
    local pos = targetRoot.Position
    local vel = targetRoot.AssemblyLinearVelocity
    local moveDir = targetHumanoid.MoveDirection
    local predDefault = getDefaultPrediction(pos, vel, moveDir)
    local predV2 = getV2Prediction(pos, vel)
    local predHybrid = (predDefault + predV2) / 2
    local predMega = GetMegaPrediction(targetRoot, targetHumanoid)
    local predUltra = (predDefault + predV2 + predHybrid + predMega) / 4
    local predNew = getNewPrediction(targetRoot, targetHumanoid)
    local predExtreme = getExtremePrediction(targetRoot, targetHumanoid)
    local predUltimate = getUltimatePrediction(targetRoot, targetHumanoid, ping)
    local sum = predDefault + predV2 + predHybrid + predMega + predUltra + predNew + predExtreme + predUltimate
    return sum / 8
end

-- Mode Velocity (kecepatan linier + gravitasi)
local PROJECTILE_SPEED = 100
local GRAVITY = 196.2
local function getVelocityPrediction(targetRoot, targetHumanoid, origin)
    local pos = targetRoot.Position
    local vel = targetRoot.AssemblyLinearVelocity
    local distance = (pos - origin).Magnitude
    local travelTime = distance / PROJECTILE_SPEED
    local predictedPos = pos + vel * travelTime
    local drop = 0.5 * GRAVITY * travelTime^2
    return predictedPos - Vector3.new(0, drop, 0)
end

-- Mode Movement (kecepatan dari perubahan posisi)
local lastPositions = {}
local function getMovementPrediction(targetRoot, targetHumanoid)
    local pos = targetRoot.Position
    local targetKey = tostring(targetRoot)
    local lastPos = lastPositions[targetKey] or pos
    local vel = (pos - lastPos) / 0.1
    lastPositions[targetKey] = pos
    task.delay(2, function() lastPositions[targetKey] = nil end)
    return pos + vel * 0.2
end

-- Mode Interpolation (smoothing + ekstrapolasi)
local smoothedPositions = {}
local function getInterpolationPrediction(targetRoot, targetHumanoid)
    local pos = targetRoot.Position
    local targetKey = tostring(targetRoot)
    local lastSmoothed = smoothedPositions[targetKey] or pos
    local smoothed = lastSmoothed:Lerp(pos, 0.7)
    smoothedPositions[targetKey] = smoothed
    task.delay(2, function() smoothedPositions[targetKey] = nil end)
    local vel = targetRoot.AssemblyLinearVelocity
    return smoothed + vel * 0.16
end

-- Mode Trajectory (parabola + kecepatan target)
local function getTrajectoryPrediction(targetRoot, targetHumanoid, origin)
    local head = targetRoot.Parent:FindFirstChild("Head") or targetRoot
    local pos = head.Position
    local vel = targetRoot.AssemblyLinearVelocity
    local distance = (pos - origin).Magnitude
    local travelTime = distance / PROJECTILE_SPEED
    local predictedPos = pos + vel * travelTime
    local yOffset = -0.5 * GRAVITY * travelTime^2
    return predictedPos + Vector3.new(0, yOffset, 0)
end

-- Mode HybridAll (rata-rata 4 mode di atas)
local function getHybridAllPrediction(targetRoot, targetHumanoid, origin)
    local predVel = getVelocityPrediction(targetRoot, targetHumanoid, origin)
    local predMov = getMovementPrediction(targetRoot, targetHumanoid)
    local predInt = getInterpolationPrediction(targetRoot, targetHumanoid)
    local predTraj = getTrajectoryPrediction(targetRoot, targetHumanoid, origin)
    return (predVel + predMov + predInt + predTraj) / 4
end

-- Mode TotalOmni (rata-rata semua 15 mode)
local function getTotalOmniPrediction(targetRoot, targetHumanoid, ping, origin)
    local pos = targetRoot.Position
    local vel = targetRoot.AssemblyLinearVelocity
    local moveDir = targetHumanoid.MoveDirection
    local predDefault = getDefaultPrediction(pos, vel, moveDir)
    local predV2 = getV2Prediction(pos, vel)
    local predHybrid = (predDefault + predV2) / 2
    local predMega = GetMegaPrediction(targetRoot, targetHumanoid)
    local predUltra = (predDefault + predV2 + predHybrid + predMega) / 4
    local predNew = getNewPrediction(targetRoot, targetHumanoid)
    local predExtreme = getExtremePrediction(targetRoot, targetHumanoid)
    local predUltimate = getUltimatePrediction(targetRoot, targetHumanoid, ping)
    local predOmni = getOmniPrediction(targetRoot, targetHumanoid, ping)
    local predVelocity = getVelocityPrediction(targetRoot, targetHumanoid, origin)
    local predMovement = getMovementPrediction(targetRoot, targetHumanoid)
    local predInterpolation = getInterpolationPrediction(targetRoot, targetHumanoid)
    local predTrajectory = getTrajectoryPrediction(targetRoot, targetHumanoid, origin)
    local predHybridAll = getHybridAllPrediction(targetRoot, targetHumanoid, origin)
    local sum = predDefault + predV2 + predHybrid + predMega + predUltra + predNew + predExtreme +
                predUltimate + predOmni + predVelocity + predMovement + predInterpolation +
                predTrajectory + predHybridAll
    return sum / 14  -- 14 mode karena Omni sudah termasuk beberapa, tapi total unik 14? Hitung: Default,V2,Hybrid,Mega,Ultra,New,Extreme,Ultimate,Omni,Velocity,Movement,Interpolation,Trajectory,HybridAll = 14. TotalOmni = rata-rata 14 mode.
    -- Jika ingin 15, tambahkan satu lagi, tetapi kita akan gunakan 14.
end
local function getDefaultPrediction(playerPosition, velocity, moveDirection)
    local offset = KNIFE_OFFSET
    local predictedPos = playerPosition + (velocity * Vector3.new(0.75, 0.5, 0.75)) * (offset / 15) + moveDirection * offset
    if COMBINE_VELOCITY_12 then predictedPos = predictedPos + (velocity * 0.12) end
    local ping = lp:GetNetworkPing() * 1000
    local pingMultiplier = ((ping) * ((KNIFE_PING_MULTIPLIER - 1) * 0.01)) + 1
    return predictedPos * pingMultiplier
end

local function getV2Prediction(playerPosition, velocity)
    local predTime = 16 / 100
    return playerPosition + Vector3.new(velocity.X, 0, velocity.Z) * predTime
end

local function GetKnifePredictedPosition(targetRoot, targetHumanoid)
    if not targetRoot or not targetHumanoid then
        return targetRoot and targetRoot.Position or Vector3.new(0,0,0)
    end
    local pos = targetRoot.Position
    local vel = targetRoot.AssemblyLinearVelocity
    local moveDir = targetHumanoid.MoveDirection
    local origin = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
    origin = origin and origin.Position or Vector3.new(0,0,0)
    local ping = lp:GetNetworkPing() * 1000

    if PREDICTION_MODE == "V2" then
        return getV2Prediction(pos, vel)
    elseif PREDICTION_MODE == "Hybrid" then
        local pred1 = getDefaultPrediction(pos, vel, moveDir)
        local pred2 = getV2Prediction(pos, vel)
        return (pred1 + pred2) / 2
    elseif PREDICTION_MODE == "Mega" then
        return GetMegaPrediction(targetRoot, targetHumanoid)
    elseif PREDICTION_MODE == "Ultra" then
        local predDefault = getDefaultPrediction(pos, vel, moveDir)
        local predV2 = getV2Prediction(pos, vel)
        local predHybrid = (predDefault + predV2) / 2
        local predMega = GetMegaPrediction(targetRoot, targetHumanoid)
        return (predDefault + predV2 + predHybrid + predMega) / 4
    elseif PREDICTION_MODE == "New" then
        return getNewPrediction(targetRoot, targetHumanoid)
    elseif PREDICTION_MODE == "Extreme" then
        return getExtremePrediction(targetRoot, targetHumanoid)
    elseif PREDICTION_MODE == "Ultimate" then
        return getUltimatePrediction(targetRoot, targetHumanoid, ping)
    elseif PREDICTION_MODE == "Omni" then
        return getOmniPrediction(targetRoot, targetHumanoid, ping)
    elseif PREDICTION_MODE == "Velocity" then
        return getVelocityPrediction(targetRoot, targetHumanoid, origin)
    elseif PREDICTION_MODE == "Movement" then
        return getMovementPrediction(targetRoot, targetHumanoid)
    elseif PREDICTION_MODE == "Interpolation" then
        return getInterpolationPrediction(targetRoot, targetHumanoid)
    elseif PREDICTION_MODE == "Trajectory" then
        return getTrajectoryPrediction(targetRoot, targetHumanoid, origin)
    elseif PREDICTION_MODE == "HybridAll" then
        return getHybridAllPrediction(targetRoot, targetHumanoid, origin)
    elseif PREDICTION_MODE == "TotalOmni" then
        return getTotalOmniPrediction(targetRoot, targetHumanoid, ping, origin)
    else -- Default
        return getDefaultPrediction(pos, vel, moveDir)
    end
end

