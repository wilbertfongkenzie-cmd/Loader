-- ==================== HELPER FUNCTIONS ====================
local function GetPlayerTeam(player)
    if not player or not player.Character then return "Unknown" end
    if player.TeamColor then
        if player.TeamColor == BrickColor.new("Bright red") or player.TeamColor == BrickColor.new("Really red") then return "Red" end
        if player.TeamColor == BrickColor.new("Bright blue") or player.TeamColor == BrickColor.new("Really blue") then return "Blue" end
    end
    local char = player.Character
    local highlight = char:FindFirstChild("Highlight")
    if highlight then
        if highlight.FillColor == Color3.fromRGB(255, 0, 0) then return "Red" end
        if highlight.FillColor == Color3.fromRGB(0, 0, 255) then return "Blue" end
    end
    local teamAttr = char:GetAttribute("Team")
    if teamAttr then
        if teamAttr:lower() == "red" then return "Red" end
        if teamAttr:lower() == "blue" then return "Blue" end
    end
    return "Unknown"
end

local function IsEnemy(player)
    if player == lp then return false end
    local myTeam = GetPlayerTeam(lp)
    local targetTeam = GetPlayerTeam(player)
    if myTeam == "Unknown" or targetTeam == "Unknown" then return true end
    return myTeam ~= targetTeam
end

local function IsBot(model)
    if not model or model == lp.Character then return false end
    if Players:FindFirstChild(model.Name) then return false end
    local hum = model:FindFirstChildWhichIsA("Humanoid")
    local hrp = model:FindFirstChild("HumanoidRootPart") or model:FindFirstChild("Torso")
    return hum ~= nil and hrp ~= nil and hum.Health > 0
end

local function GetClosestTarget()
    if not lp.Character or not lp.Character:FindFirstChild("HumanoidRootPart") then return nil, nil end
    local localRoot = lp.Character.HumanoidRootPart
    local closest, closestDist = nil, math.huge
    local targetType = nil

    if _G.TargetMode == "Players" or _G.TargetMode == "All" then
        for _, player in pairs(Players:GetPlayers()) do
            if IsEnemy(player) and player.Character then
                local targetRoot = player.Character:FindFirstChild("HumanoidRootPart")
                if targetRoot then
                    local dist = (localRoot.Position - targetRoot.Position).Magnitude
                    if dist < closestDist and dist <= 100 then
                        closestDist = dist
                        closest = player.Character
                        targetType = "Player"
                    end
                end
            end
        end
    end

    if _G.TargetMode == "Bots" or _G.TargetMode == "All" then
        for _, obj in pairs(workspace:GetDescendants()) do
            if obj:IsA("Model") and IsBot(obj) then
                local targetRoot = obj:FindFirstChild("HumanoidRootPart") or obj:FindFirstChild("Torso")
                if targetRoot then
                    local dist = (localRoot.Position - targetRoot.Position).Magnitude
                    if dist < closestDist and dist <= 100 then
                        closestDist = dist
                        closest = obj
                        targetType = "Bot"
                    end
                end
            end
        end
    end

    return closest, targetType
end

-- ==================== GUN SYSTEM ====================
local function isPlayerSheriff(player)
    if not player then return false end
    local function check(tool)
        if not tool:IsA("Tool") then return false end
        if tool:FindFirstChild("GunServer") and tool.GunServer:IsA("Script") then return true end
        return false
    end
    if player.Character then
        for _, tool in pairs(player.Character:GetChildren()) do if check(tool) then return true end end
    end
    if player.Backpack then
        for _, tool in pairs(player.Backpack:GetChildren()) do if check(tool) then return true end end
    end
    return false
end

local function getPlayerWeapon(player)
    if not player then return nil, nil, nil end
    local function search(tool)
        if not tool:IsA("Tool") then return nil, nil, nil end
        local gunServer = tool:FindFirstChild("GunServer")
        if gunServer then
            local shootStart = gunServer:FindFirstChild("ShootStart")
            if shootStart and (shootStart:IsA("RemoteEvent") or shootStart:IsA("RemoteFunction")) then
                return tool, tool.Name, {type = "gunserver_inside", remote = shootStart}
            end
        end
        local direct = tool:FindFirstChild("ShootStart")
        if direct and (direct:IsA("RemoteEvent") or direct:IsA("RemoteFunction")) then
            return tool, tool.Name, {type = "direct", remote = direct}
        end
        return nil, nil, nil
    end
    if player.Character then
        for _, tool in pairs(player.Character:GetChildren()) do
            local found, name, info = search(tool)
            if found then return found, name, info end
        end
    end
    if player.Backpack then
        for _, tool in pairs(player.Backpack:GetChildren()) do
            local found, name, info = search(tool)
            if found then return found, name, info end
        end
    end
    return nil, nil, nil
end

local function getMyWeapon() return getPlayerWeapon(lp) end

-- Gun prediction: velocity * 0.12 (no X/Y/Z offsets)
local function GetGunPredictedPosition(targetRoot)
    if not targetRoot then return nil end
    local success, velocity = pcall(function() return targetRoot.AssemblyLinearVelocity end)
    if not success or not velocity then return targetRoot.Position end
    return targetRoot.Position + (velocity * GUN_PREDICTION_TIME)
end

local function fireGun()
    if not lp.Character then return end
    local char = lp.Character
    local weapon, _, weaponInfo = getMyWeapon()
    if not weapon then
        WindUI:Notify({Title = "Error", Content = "No weapon found. You must be Sheriff.", Duration = 2})
        return
    end
    local target, targetType = GetClosestTarget()
    if not target then return end

    local targetRoot = target:FindFirstChild("HumanoidRootPart") or target:FindFirstChild("Torso")
    if not targetRoot then return end

    if weapon.Parent == lp.Backpack then
        local hum = char:FindFirstChild("Humanoid")
        if hum then hum:EquipTool(weapon); task.wait(0.1) end
    end

    local predictedPos = GetGunPredictedPosition(targetRoot) or targetRoot.Position
    local shootRemote = weaponInfo and weaponInfo.remote
    if shootRemote then
        pcall(function()
            if shootRemote:IsA("RemoteEvent") then shootRemote:FireServer(predictedPos)
            elseif shootRemote:IsA("RemoteFunction") then shootRemote:InvokeServer(predictedPos) end
        end)

        -- Visual effect
        local origin = char.HumanoidRootPart.Position
        local beam = Instance.new("Part")
        beam.Shape = Enum.PartType.Block
        beam.Size = Vector3.new(0.2, 0.2, (predictedPos - origin).Magnitude)
        beam.CFrame = CFrame.new(origin, predictedPos) * CFrame.new(0, 0, -beam.Size.Z/2)
        beam.Color = Color3.fromRGB(255, 0, 0)
        beam.Material = Enum.Material.Neon
        beam.Anchored = true
        beam.CanCollide = false
        beam.Parent = workspace
        game:GetService("Debris"):AddItem(beam, 0.1)

        WindUI:Notify({Title = "Shot", Content = "Fired at " .. target.Name, Duration = 1})
    end
end

