    if not flyEnabled then return end
    local k = input.KeyCode.Name:lower()
    if k=="w" then flyDir.f = 0 elseif k=="s" then flyDir.b = 0
    elseif k=="a" then flyDir.l = 0 elseif k=="d" then flyDir.r = 0 end
end)

