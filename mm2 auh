-- Fungsi untuk mencari remote di seluruh hierarki (rekursif)
local function findRemoteInTool(tool, remoteNames)
    if not tool then return nil end
    for _, name in ipairs(remoteNames) do
        local found = tool:FindFirstChild(name)
        if found and found:IsA("RemoteEvent") then
            return found, name
        end
        -- cari di dalam folder seperti "Events"
        for _, child in pairs(tool:GetChildren()) do
            if child:IsA("Folder") or child:IsA("Configuration") then
                local deep = child:FindFirstChild(name)
                if deep and deep:IsA("RemoteEvent") then
                    return deep, name
                end
            end
        end
    end
    -- cari semua remote event di tool (rekursif)
    local allRemotes = {}
    local function scan(obj)
        for _, child in pairs(obj:GetChildren()) do
            if child:IsA("RemoteEvent") then
                table.insert(allRemotes, child)
            end
            scan(child)
        end
    end
    scan(tool)
    if #allRemotes > 0 then
        return allRemotes[1], allRemotes[1].Name
    end
    return nil, nil
end

