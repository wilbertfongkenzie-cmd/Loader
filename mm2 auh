local function PlayThrowAnimationSequence()
    local character = lp.Character
    if not character then return false end
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if not humanoid then return false end
    if currentAnimTrack and currentAnimTrack.IsPlaying then currentAnimTrack:Stop() end
    if currentAnimTrack2 and currentAnimTrack2.IsPlaying then currentAnimTrack2:Stop() end
    local chargeTrack = LoadAnimationFromId(THROW_CHARGE_ANIM_ID)
    local throwTrack = LoadAnimationFromId(THROW_KNIFE_ANIM_ID)
    task.spawn(function()
        if chargeTrack then
            currentAnimTrack = chargeTrack
            currentAnimTrack:Play()
            local startTime = tick()
            while currentAnimTrack and currentAnimTrack.IsPlaying and (tick() - startTime) < ANIMATION_DELAY do
                task.wait()
            end
            if currentAnimTrack and currentAnimTrack.IsPlaying then currentAnimTrack:Stop() end
        else
