-- ===== 15. QUANTUM PREDICTION =====
local function getQuantumPrediction(targetRoot, targetHumanoid, ping, origin)
    local pos = targetRoot.Position
    local vel = targetRoot.AssemblyLinearVelocity
    local moveDir = targetHumanoid.MoveDirection
    local distance = (pos - origin).Magnitude
    
    local speedFactor = math.clamp(vel.Magnitude / 40, 0.3, 2.5)
    local distanceFactor = math.clamp(distance / 50, 0.5, 2)
    local pingFactor = 1 + (ping or 0) * 0.0005
    
    local predLinear = pos + vel * 0.3 + moveDir * 2.5
    local predHorizontal = pos + Vector3.new(vel.X, 0, vel.Z) * 0.2
    local predVertical = pos + Vector3.new(0, vel.Y * 0.15, 0)
    
    local isJumping = (targetHumanoid.FloorMaterial == Enum.Material.Air and targetHumanoid.JumpPower > 0)
    local jumpBonus = isJumping and Vector3.new(0, 5, 0) or Vector3.new(0, 0, 0)
    
    local weights = {
        linear = 0.4 * speedFactor,
        horizontal = 0.3 * distanceFactor,
        vertical = 0.3 * pingFactor
    }
    
    local totalWeight = weights.linear + weights.horizontal + weights.vertical
    local result = (predLinear * weights.linear + 
                    predHorizontal * weights.horizontal + 
                    predVertical * weights.vertical) / totalWeight + jumpBonus
    
    local maxOffset = 30
    local offset = (result - pos).Magnitude
    if offset > maxOffset then
        result = pos + (result - pos).Unit * maxOffset
    end
    
    return result
end

