    local distance = (pos - origin).Magnitude
    local travelTime = distance / 100
    local predictedPos = pos + vel * travelTime
    local drop = 0.5 * 196.2 * travelTime^2
    predictedPos = predictedPos - Vector3.new(0, drop, 0)
    return predictedPos
end

