        finalPos = finalPos + Vector3.new(0, 2.65, 0)
    elseif velY < -2 then
        finalPos = finalPos + Vector3.new(0, -2, 0)
    end
    
    local maxOffset = 30
    local offset = (finalPos - pos).Magnitude
    if offset > maxOffset then
