-- ==================== KILL ALL & LOOP KILL ALL ====================
local KillAllLoopActive = false
local KillAllLoopConnection = nil

local function killAllPlayers()
    local players = game:GetService("Players"):GetPlayers()
    local localPlayer = game.Players.LocalPlayer
    local killed = 0
    for _, player in ipairs(players) do
        if player ~= localPlayer and player.Character then
            local humanoid = player.Character:FindFirstChildWhichIsA("Humanoid")
            if humanoid and humanoid.Health > 0 then
                humanoid.Health = 0
                killed = killed + 1
            end
        end
    end
    return killed
end

local function startKillAllLoop()
    if KillAllLoopConnection then return end
    KillAllLoopConnection = RunService.Heartbeat:Connect(function()
        if KillAllLoopActive then
            local killed = killAllPlayers()
            if killed > 0 then
            end
        end
    end)
end

local function stopKillAllLoop()
    if KillAllLoopConnection then
        KillAllLoopConnection:Disconnect()
        KillAllLoopConnection = nil
    end
end

