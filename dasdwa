                    predExtreme * weights.extreme + 
                    predHybrid4 * weights.hybrid4 + 
                    predOmni * weights.omni + 
                    predDefault * weights.default + 
                    predMega * weights.mega) / totalWeight
    
    local isJumping = (targetHumanoid.FloorMaterial == Enum.Material.Air and targetHumanoid.JumpPower > 0)
    if isJumping then
        result = result + Vector3.new(0, 7, 0)
    end
    
    local velY = vel.Y
    if velY > 2.65 then
        result = result + Vector3.new(0, 2.65, 0)
    elseif velY < -2 then
        result = result + Vector3.new(0, -2, 0)
    end
    
    local maxOffset = 30
    local offset = (result - pos).Magnitude
    if offset > maxOffset then
        result = pos + (result - pos).Unit * maxOffset
    end
    
    return result
end

-- ===== 22. ULTRA OMNI PREDICTION =====
local function getUltraOmniPrediction(targetRoot, targetHumanoid, ping, origin)
    if not targetRoot or not targetHumanoid then
        return targetRoot and targetRoot.Position or Vector3.new(0, 0, 0)
    end
    
    local pos = targetRoot.Position
    local vel = targetRoot.AssemblyLinearVelocity
    local moveDir = targetHumanoid.MoveDirection
    
    local predDefault = getDefaultPrediction(pos, vel, moveDir)
    local predV2 = getV2Prediction(pos, vel)
    local predHybrid = (predDefault + predV2) / 2
    local predMega = GetMegaPrediction(targetRoot, targetHumanoid)
    local predUltra = (predDefault + predV2 + predHybrid + predMega) / 4
    local predNew = getNewPrediction(targetRoot, targetHumanoid)
    local predUltraEdit = getUltraEditPrediction(targetRoot, targetHumanoid, ping)
    local predExtreme = getExtremePrediction(targetRoot, targetHumanoid)
    local predUltimate = getUltimatePrediction(targetRoot, targetHumanoid, ping)
    local predOmni = getOmniPrediction(targetRoot, targetHumanoid, ping)
    local predVelocity = getVelocityPrediction(targetRoot, targetHumanoid, origin)
    local predMovement = getMovementPrediction(targetRoot, targetHumanoid)
    local predInterpolation = getInterpolationPrediction(targetRoot, targetHumanoid)
    local predTrajectory = getTrajectoryPrediction(targetRoot, targetHumanoid, origin)
    local predQuantum = getQuantumPrediction(targetRoot, targetHumanoid, ping, origin)
    local predPosition = getPositionPrediction(targetRoot, targetHumanoid)
    local predAngleVal = getAnglePredictionValue(targetRoot, targetHumanoid, origin)
    local predSpeedVal = getSpeedPredictionValue(targetRoot, targetHumanoid)
    local predVertical = getVerticalPrediction(targetRoot, targetHumanoid)
    local predHybrid4 = getHybrid4Prediction(targetRoot, targetHumanoid, origin)
    local predUltimatePro = getUltimateProPrediction(targetRoot, targetHumanoid, ping, origin)
    
    local predAngle = origin + (pos - origin).Unit * math.cos(math.rad(predAngleVal)) * (pos - origin).Magnitude + Vector3.new(0, math.sin(math.rad(predAngleVal)) * (pos - origin).Magnitude, 0)
    local predSpeed = pos + vel.Unit * predSpeedVal * 0.3
    
    local sum = predDefault + predV2 + predHybrid + predMega + predUltra + 
                predNew + predUltraEdit + predExtreme + predUltimate + 
                predOmni + predVelocity + predMovement + predInterpolation + 
                predTrajectory + predQuantum + predPosition + predAngle + 
                predSpeed + predVertical + predHybrid4 + predUltimatePro
    
    return sum / 22
end

-- ==================== FUNGSI GET PREDICTED POSITION ====================
local function GetKnifePredictedPosition(targetRoot, targetHumanoid)
    if not targetRoot or not targetHumanoid then
        return targetRoot and targetRoot.Position or Vector3.new(0, 0, 0)
    end
    
    local pos = targetRoot.Position
    local vel = targetRoot.AssemblyLinearVelocity
    local moveDir = targetHumanoid.MoveDirection
    local origin = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
    origin = origin and origin.Position or Vector3.new(0, 0, 0)
    local ping = lp:GetNetworkPing() * 1000
    
    if PREDICTION_MODE == "Default" then
        return getDefaultPrediction(pos, vel, moveDir)
    elseif PREDICTION_MODE == "V2" then
        return getV2Prediction(pos, vel)
    elseif PREDICTION_MODE == "Hybrid" then
        return getHybridPrediction(pos, vel, moveDir)
    elseif PREDICTION_MODE == "Mega" then
        return GetMegaPrediction(targetRoot, targetHumanoid)
    elseif PREDICTION_MODE == "Ultra" then
        return getUltraPrediction(pos, vel, moveDir, targetRoot, targetHumanoid)
    elseif PREDICTION_MODE == "New" then
        return getNewPrediction(targetRoot, targetHumanoid)
    elseif PREDICTION_MODE == "Ultra Edit" then
        return getUltraEditPrediction(targetRoot, targetHumanoid, ping)
    elseif PREDICTION_MODE == "Extreme" then
        return getExtremePrediction(targetRoot, targetHumanoid)
    elseif PREDICTION_MODE == "Ultimate" then
        return getUltimatePrediction(targetRoot, targetHumanoid, ping)
    elseif PREDICTION_MODE == "Omni" then
        return getOmniPrediction(targetRoot, targetHumanoid, ping)
    elseif PREDICTION_MODE == "Velocity" then
        return getVelocityPrediction(targetRoot, targetHumanoid, origin)
    elseif PREDICTION_MODE == "Movement" then
        return getMovementPrediction(targetRoot, targetHumanoid)
    elseif PREDICTION_MODE == "Interpolation" then
        return getInterpolationPrediction(targetRoot, targetHumanoid)
    elseif PREDICTION_MODE == "Trajectory" then
        return getTrajectoryPrediction(targetRoot, targetHumanoid, origin)
    elseif PREDICTION_MODE == "Quantum" then
        return getQuantumPrediction(targetRoot, targetHumanoid, ping, origin)
    elseif PREDICTION_MODE == "Position" then
        return getPositionPrediction(targetRoot, targetHumanoid)
    elseif PREDICTION_MODE == "Angle" then
        local angle = getAnglePredictionValue(targetRoot, targetHumanoid, origin)
        local direction = (pos - origin).Unit
        local angleRad = math.rad(angle)
        local horizontalDistance = (pos - origin).Magnitude
        local newY = math.sin(angleRad) * horizontalDistance
        local newXZ = math.cos(angleRad) * horizontalDistance
        return origin + direction * newXZ + Vector3.new(0, newY, 0)
    elseif PREDICTION_MODE == "Speed" then
        local speed = getSpeedPredictionValue(targetRoot, targetHumanoid)
        return pos + vel.Unit * speed * 0.3
    elseif PREDICTION_MODE == "Vertical" then
        return getVerticalPrediction(targetRoot, targetHumanoid)
    elseif PREDICTION_MODE == "Hybrid4" then
        return getHybrid4Prediction(targetRoot, targetHumanoid, origin)
    elseif PREDICTION_MODE == "UltimatePro" then
        return getUltimateProPrediction(targetRoot, targetHumanoid, ping, origin)
    elseif PREDICTION_MODE == "UltraOmni" then
        return getUltraOmniPrediction(targetRoot, targetHumanoid, ping, origin)
    else
        return getUltraOmniPrediction(targetRoot, targetHumanoid, ping, origin)
    end
end

