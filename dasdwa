-- ===== 1. DEFAULT PREDICTION =====
local function getDefaultPrediction(playerPosition, velocity, moveDirection)
    local offset = KNIFE_OFFSET or 2.8
    local predictedPos = playerPosition + (velocity * Vector3.new(0.75, 0.5, 0.75)) * (offset / 15) + moveDirection * offset
    if COMBINE_VELOCITY_12 then predictedPos = predictedPos + (velocity * 0.12) end
    local ping = lp:GetNetworkPing() * 1000
    local pingMultiplier = ((ping) * ((KNIFE_PING_MULTIPLIER - 1) * 0.01)) + 1
    return predictedPos * pingMultiplier
end

-- ===== 2. V2 PREDICTION =====
local function getV2Prediction(playerPosition, velocity)
    local predTime = 16 / 100
    return playerPosition + Vector3.new(velocity.X, 0, velocity.Z) * predTime
end

-- ===== 3. HYBRID PREDICTION =====
local function getHybridPrediction(pos, vel, moveDir)
    local pred1 = getDefaultPrediction(pos, vel, moveDir)
    local pred2 = getV2Prediction(pos, vel)
    return (pred1 + pred2) / 2
end

-- ===== 4. MEGA PREDICTION =====
local function GetMegaPrediction(targetRoot, targetHumanoid)
    if not targetRoot or not targetHumanoid then
        return targetRoot and targetRoot.Position or Vector3.new(0, 0, 0)
    end
    local rootPart = targetRoot
    local velocity = rootPart.AssemblyLinearVelocity
    local moveDir = targetHumanoid.MoveDirection
    local playerPosition = rootPart.Position
    local seismicPos = playerPosition
    if velocity.Magnitude ~= 0 then
        local pred = velocity.Unit * velocity.Magnitude / 16.5
        local y = pred.Y
        y = y > 2.65 and 2.65 or (y < -2 and -2 or y)
        seismicPos = playerPosition + Vector3.new(pred.X, y, pred.Z / 1.25)
    end
    local overflowPos = playerPosition
    if velocity.Magnitude ~= 0 then
        local pred = velocity.Unit * velocity.Magnitude / 17 + moveDir
        local y = pred.Y
        y = y > 2.5 and 2.5 or (y < -2 and -2 or y)
        overflowPos = playerPosition + Vector3.new(pred.X, y, pred.Z)
    end
    local predictedPos = (seismicPos + overflowPos) / 2
    local distance = (predictedPos - playerPosition).Magnitude
    if distance > 30 then predictedPos = playerPosition end
    return predictedPos
end

-- ===== 5. ULTRA PREDICTION =====
local function getUltraPrediction(pos, vel, moveDir, targetRoot, targetHumanoid)
    local p1 = getDefaultPrediction(pos, vel, moveDir)
    local p2 = getV2Prediction(pos, vel)
    local p3 = (p1 + p2) / 2
    local p4 = GetMegaPrediction(targetRoot, targetHumanoid)
    return (p1 + p2 + p3 + p4) / 4
end

-- ===== 6. NEW PREDICTION =====
local function getNewPrediction(targetRoot, targetHumanoid)
    local pos = targetRoot.Position
    local vel = targetRoot.AssemblyLinearVelocity
    local moveDir = targetHumanoid.MoveDirection
    local isJumping = (targetHumanoid.JumpPower > 0 and targetHumanoid.FloorMaterial == Enum.Material.Air)
    local jumpBonus = isJumping and Vector3.new(0, 7.5, 0) or Vector3.new(0, 0, 0)
    return pos + vel * 0.4 + moveDir * 2.5 + jumpBonus
end

-- ===== 7. ULTRA EDIT PREDICTION =====
local function getUltraEditPrediction(targetRoot, targetHumanoid, ping)
    local pos = targetRoot.Position
    local vel = targetRoot.AssemblyLinearVelocity
    local moveDir = targetHumanoid.MoveDirection
    
    local predDefault = getDefaultPrediction(pos, vel, moveDir)
    local predV2 = getV2Prediction(pos, vel)
    local predHybrid = (predDefault + predV2) / 2
    local predMega = GetMegaPrediction(targetRoot, targetHumanoid)
    local predNew = getNewPrediction(targetRoot, targetHumanoid)
    
    local speedFactor = math.clamp(vel.Magnitude / 50, 0.5, 2)
    local weights = {
        default = 0.2 * speedFactor,
        v2 = 0.2,
        hybrid = 0.2,
        mega = 0.3,
        new = 0.3 / speedFactor
    }
    local totalWeight = weights.default + weights.v2 + weights.hybrid + weights.mega + weights.new
    local finalPos = (predDefault * weights.default + predV2 * weights.v2 + predHybrid * weights.hybrid + 
                     predMega * weights.mega + predNew * weights.new) / totalWeight
    
    local pingCompensation = (ping or 0) * 0.08
    return finalPos + (vel * pingCompensation)
end

