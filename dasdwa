    local predV2 = getV2Prediction(pos, vel)
    local predHybrid = (predDefault + predV2) / 2
    local predMega = GetMegaPrediction(targetRoot, targetHumanoid)
    local predUltra = (predDefault + predV2 + predHybrid + predMega) / 4
    local predNew = getNewPrediction(targetRoot, targetHumanoid)
    local predUltraEdit = getUltraEditPrediction(targetRoot, targetHumanoid, ping)
    local predExtreme = getExtremePrediction(targetRoot, targetHumanoid)
    local predUltimate = getUltimatePrediction(targetRoot, targetHumanoid, ping)
    
    local sum = predDefault + predV2 + predHybrid + predMega + predUltra + 
                predNew + predUltraEdit + predExtreme + predUltimate
    return sum / 9
end

