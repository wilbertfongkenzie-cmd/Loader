local function identifyPlayerRole(player)
    if player == lp then return "Local" end
    if isPlayerMurderer(player) then return "Murderer" end
    if player.Character then
        for _, tool in pairs(player.Character:GetDescendants()) do
            if tool:IsA("Tool") and string.lower(tool.Name) == "gun" then return "Sheriff" end
