local function SkidFling(TargetPlayer)
    local Character = lp.Character
    local Humanoid = Character and Character:FindFirstChildOfClass("Humanoid")
    local RootPart = Humanoid and Humanoid.RootPart
    local TCharacter = TargetPlayer.Character
    if not TCharacter then return end
    local THumanoid = TCharacter:FindFirstChildOfClass("Humanoid")
    local TRootPart = THumanoid and THumanoid.RootPart
    if not (Character and Humanoid and RootPart and THumanoid and TRootPart) then
        WindUI:Notify({Title = "Fling", Content = "Cannot fling target!", Duration = 2})
        return
    end
    if RootPart.Velocity.Magnitude < 50 then OldPos = RootPart.CFrame end
    if not FPDH then FPDH = Workspace.FallenPartsDestroyHeight end
    Workspace.FallenPartsDestroyHeight = 0/0
    local function FPos(BasePart, Pos, Ang)
        RootPart.CFrame = CFrame.new(BasePart.Position) * Pos * Ang
        Character:SetPrimaryPartCFrame(CFrame.new(BasePart.Position) * Pos * Ang)
        RootPart.Velocity = Vector3.new(9e7, 9e7, 9e7)
        RootPart.RotVelocity = Vector3.new(9e8, 9e8, 9e8)
    end
    local StartTime = tick()
    local Duration = 2
    repeat
        FPos(TRootPart, CFrame.new(0, 1.5, 0), CFrame.Angles(math.rad(90), 0, 0))
        task.wait()
        FPos(TRootPart, CFrame.new(0, -1.5, 0), CFrame.Angles(0, 0, 0))
        task.wait()
    until tick() - StartTime > Duration
    if OldPos then
        RootPart.CFrame = OldPos
        Character:SetPrimaryPartCFrame(OldPos)
        for _, Part in ipairs(Character:GetDescendants()) do
            if Part:IsA("BasePart") then
                Part.Velocity = Vector3.new()
                Part.RotVelocity = Vector3.new()
            end
        end
    end
    Workspace.FallenPartsDestroyHeight = FPDH
    WindUI:Notify({Title = "Fling", Content = "Flinged " .. TargetPlayer.Name, Duration = 2})
end

local function FlingAll()
    local Count = 0
    for _, Player in ipairs(Players:GetPlayers()) do
        if Player ~= lp then
            SkidFling(Player)
            Count = Count + 1
            task.wait(0.2)
        end
    end
    WindUI:Notify({Title = "Fling All", Content = "Flinged " .. Count .. " players!", Duration = 3})
end

local function TouchFlingLoop()
